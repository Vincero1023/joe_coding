{
  "manifest_version": 3,
  "name": "Agoda Campaign Scanner",
  "version": "0.3.0",
  "description": "Scan Agoda cid/tag campaign links, rank the cheapest results, and open the best one.",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.agoda.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Agoda Campaign Scanner",
    "default_popup": "popup.html"
  }
}
