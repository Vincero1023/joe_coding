// ----------------------------------------------------
// [0] ?좏떥由ы떚
// ----------------------------------------------------
const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

// ?띿뒪?몃줈 ?붿냼 李얘린 (Top Frame)
function findElementByText(text) {
    const doc = window.top.document; 
    const cleanTarget = text.replace(/\s/g, '');
    const all = doc.querySelectorAll('label, span, strong, b, div, p, h3, h4, li, a, button');
    
    for (let el of all) {
        if (el.innerText.replace(/\s/g, '').includes(cleanTarget) && el.offsetParent !== null) {
            if (el.childElementCount === 0) return el;
        }
    }
    return null;
}

// ??Tab) ?대룞: 湲곗? ?붿냼 諛붾줈 ?ㅼ쓬??'?낅젰 媛???붿냼' 諛섑솚
function getNextTabbable(anchor) {
    if (!anchor) return null;
    const doc = window.top.document;
    
    // ??媛?ν븳 紐⑤뱺 ?붿냼 (?붾㈃??蹂댁씠??寃껊쭔)
    const all = Array.from(doc.querySelectorAll('button, input, select, textarea, [tabindex]:not([tabindex="-1"])'))
        .filter(el => el.offsetWidth > 0 && el.offsetHeight > 0 && !el.disabled);

    for (let el of all) {
        if (anchor.compareDocumentPosition(el) & Node.DOCUMENT_POSITION_FOLLOWING) {
            return el;
        }
    }
    return null;
}

// key press helper
function pressKey(element, key = 'Enter') {
    if (!element) return;
    element.focus();

    let code = 13;
    if (key === 'Space') code = 32;
    if (key === 'ArrowLeft') code = 37;
    if (key === 'ArrowRight') code = 39;

    const opts = { key: key, code: key, keyCode: code, which: code, bubbles: true, cancelable: true, view: window };
    
    element.dispatchEvent(new KeyboardEvent('keydown', opts));
    element.dispatchEvent(new KeyboardEvent('keypress', opts));
    element.dispatchEvent(new KeyboardEvent('keyup', opts));
    
    if(key === 'Enter' || key === 'Space') element.click();
}

function setNativeValue(element, value) {
  if (!element || !(element instanceof window.HTMLInputElement)) {
      console.error("입력 가능한 요소가 아닙니다:", element);
      return;
  }
  const proto = window.HTMLInputElement.prototype;
  const setter = Object.getOwnPropertyDescriptor(proto, 'value').set;
  if (setter) setter.call(element, value);
  else element.value = value;
  element.dispatchEvent(new Event('input', { bubbles: true }));
}

// 발행 버튼 탐색 (여러 셀렉터/텍스트, 예약발행은 후순위)
function findPublishButton(doc) {
    const selectors = ['.btn_publish','button','[role="button"]','a[role="button"]','div[role="button"]','input[type="button"]','input[type="submit"]'];
    const isVisible = (el) => el && el.offsetParent !== null && el.offsetWidth > 0 && el.offsetHeight > 0 && !el.disabled;

    let best = null;
    let bestScore = -1;

    for (const sel of selectors) {
        const list = doc.querySelectorAll(sel);
        for (const el of list) {
            if (!isVisible(el)) continue;
            const rawText = (el.innerText || el.value || el.getAttribute('aria-label') || '').trim();
            if (!rawText) continue;

            const text = rawText.replace(/\s/g, '');
            const hasReserve = text.includes('예약');
            let score = -1;

            if (text.includes('발행하기') && !hasReserve) score = 5;
            else if ((text === '발행' || text.includes('발행')) && !hasReserve) score = 4;
            else if (['게시','등록','출간'].some(k => text.includes(k))) score = 3;
            else if (hasReserve && text.includes('발행')) score = 1; // 예약발행은 최후 fallback

            if (score > bestScore) {
                bestScore = score;
                best = el;
            }
        }
    }

    return best;
}

// ----------------------------------------------------
// [1] 발행 리스너
document.addEventListener('keydown', (e) => {
  if (e.altKey && e.shiftKey && (e.key === 'p' || e.key === 'P')) {
    e.preventDefault();
    window.top.postMessage({ type: "REQ_PUBLISH_EXTENSION" }, "*");
  }
});

window.addEventListener("message", (event) => {
  if (event.data && event.data.type === "REQ_PUBLISH_EXTENSION" && window === window.top) {
      runSequence();
  }
});

chrome.runtime.onMessage.addListener((request) => {
  if (request.action === "TRIGGER_PUBLISH_BY_POPUP" && window === window.top) {
      runSequence();
  }
});

// ----------------------------------------------------
// [2] 硫붿씤 濡쒖쭅
// ----------------------------------------------------
async function runSequence() {
  const topDoc = window.top.document;

  // [1] 발행 버튼 (재시도)
  let publishBtn = null;
  for (let attempt = 0; attempt < 8 && !publishBtn; attempt++) {
      publishBtn = findPublishButton(topDoc);
      if (!publishBtn) await sleep(300);
  }
  if (!publishBtn) return alert("발행 버튼을 찾지 못했습니다. 페이지 로드 상태를 확인해주세요.");

  console.log("[1] 발행 버튼 찾음");
  pressKey(publishBtn, 'Enter');

  // ?ㅼ젙 濡쒕뱶
  const data = await chrome.storage.local.get(['settings', 'currentProfile']);
  const settings = (data.settings && data.settings[data.currentProfile || 'default']) || {};
  if (!settings.category) return alert("카테고리 설정이 없습니다. 확장 설정에서 카테고리를 지정해주세요.");

  // ?좎쭨 怨꾩궛
  const [sh, sm] = (settings.startTime || '09:00').split(':').map(Number);
  let targetDate = new Date();
  if(settings.lastScheduled) {
      const last = new Date(settings.lastScheduled);
      const interval = parseInt(settings.interval || 60);
      const variance = interval * 0.2; 
      const randomMin = (Math.random() * (variance * 2)) - variance;
      last.setMinutes(last.getMinutes() + interval + randomMin);
      targetDate = last;
  } else {
      targetDate.setHours(sh, sm);
      if(targetDate < new Date()) targetDate.setDate(targetDate.getDate() + 1);
  }
  const currentProfile = data.currentProfile || "default";
  if(!data.settings[currentProfile]) data.settings[currentProfile] = {};
  data.settings[currentProfile].lastScheduled = targetDate.toISOString();
  await chrome.storage.local.set({ settings: data.settings });


  // [2] ?앹뾽 ?湲?  console.log("???앹뾽 ?湲?(2珥?...");
  await sleep(2000);

  // [3] 카테고리 설정 (드롭다운 클릭 -> 항목 클릭/Enter)
  const catLabel = findElementByText('카테고리') || topDoc.querySelector('[aria-label*="카테고리"]');
  if (catLabel) {
      let dropdown = getNextTabbable(catLabel) || catLabel.closest('label')?.querySelector('input,button,[role="combobox"],[role="button"]');
      if (dropdown) {
          dropdown.focus();
          console.log('[cat] open dropdown via click');
          dropdown.dispatchEvent(new MouseEvent('mousedown', { bubbles: true }));
          dropdown.dispatchEvent(new MouseEvent('mouseup', { bubbles: true }));
          dropdown.click();
          await sleep(500);

          const menu = topDoc.querySelector('.option_list_layer__YX1Tq');
          const norm = (s) => (s || '').replace(/\\s/g, '');
          let target = null;
          if (menu) {
              const textMatch = Array.from(menu.querySelectorAll('.item__sAGX9 .text__sraQE')).find(el => norm(el.innerText).includes(norm(settings.category)));
              if (textMatch) target = textMatch.closest('.item__sAGX9') || textMatch.closest('label') || textMatch;
          }
          if (!target) {
              const options = Array.from(topDoc.querySelectorAll('li, button, a, div'));
              const textMatch = options.find(el => el.offsetParent !== null && norm(el.innerText).includes(norm(settings.category)));
              if (textMatch) target = textMatch.closest('.item__sAGX9') || textMatch.closest('label') || textMatch;
          }

          if (target) {
              console.log(`[cat] select ${settings.category} via click`);
              target.scrollIntoView({ block: 'nearest' });
              const label = target.querySelector('label') || target;
              label.dispatchEvent(new MouseEvent('mousedown', { bubbles: true }));
              label.dispatchEvent(new MouseEvent('mouseup', { bubbles: true }));
              label.dispatchEvent(new MouseEvent('click', { bubbles: true }));
              await sleep(300);
              pressKey(label, 'Enter');
              await sleep(800);
          } else {
              console.log(`[cat] option not found: ${settings.category}`);
          }
      } else {
          console.log('[cat] dropdown focus failed');
      }
  } else {
      console.log('[cat] label not found');
  }

  // [4] 예약 설정 (발행시간 -> 날짜)
  console.log("[4] 발행 시간 확인");
  const dateBtn = topDoc.querySelector(".input_date__QmA0s");

  if (dateBtn) {
      console.log("✅ [4] 날짜 버튼 발견 (class 기반)");
      
      // 날짜 설정 로직 수행
      await setDateManual(dateBtn, targetDate);
      
      // 4. 시간 입력 (필드가 없으면 탭 순서 fallback)
      const hourInput = topDoc.querySelector("input[type='text'].input_hour__QmA0s");
      const minInput = topDoc.querySelector("input[type='text'].input_min__QmA0s");

      if (hourInput && minInput) {
          const HH = targetDate.getHours();
          const mm = Math.round(targetDate.getMinutes() / 10) * 10;
          console.log("[5] 시간 입력: " + HH + ":" + mm);
          
          setNativeValue(hourInput, String(HH).padStart(2,'0'));
          setNativeValue(minInput, String(mm).padStart(2,'0'));
      } else {
          console.log("⚠️ 시간 입력란을 찾지 못했습니다.");
      }
  } else {
      console.log("⚠️ 날짜 입력 요소(.input_date__QmA0s)를 찾지 못했습니다.");
  }


  // [5] 理쒖쥌 ?뺤씤
  await sleep(1000);
  const confirmMsg = `
  [?ㅼ젙 ?뺤씤]
  移댄뀒怨좊━: ${settings.category}
  ?덉빟?쒓컙: ${targetDate.getMonth()+1}/${targetDate.getDate()} ${targetDate.getHours()}:${Math.round(targetDate.getMinutes()/10)*10}
  
  諛쒗뻾?좉퉴??`;

  if(confirm(confirmMsg)) {
      const allBtns = topDoc.querySelectorAll('button');
      let finalBtn = null;
      let maxTop = 0;
      for(let b of allBtns) {
          if(b.innerText.trim() === '諛쒗뻾' && !b.className.includes('btn_publish') && b.offsetParent !== null) {
              const rect = b.getBoundingClientRect();
              if(rect.top > maxTop) { maxTop = rect.top; finalBtn = b; }
          }
      }
      if(finalBtn) {
          console.log("?? 理쒖쥌 諛쒗뻾 ?뷀꽣!");
          pressKey(finalBtn, 'Enter');
      }
  }
}

// ?좎쭨 ?ㅼ젙 (?ъ슜??留ㅻ돱??
// 날짜/시간 세팅 (예약 탭 힌트 기반)
// 날짜/시간 세팅 (ui-datepicker 버튼 직접 클릭)
async function setDateManual(dateBtn, targetDate) {
    const topDoc = window.top.document;
    console.log("[date] open calendar");

    pressKey(dateBtn, 'Enter');
    await sleep(300);

    const waitForCal = async () => {
        for (let i = 0; i < 5; i++) {
            const cal = topDoc.querySelector('.ui-datepicker, .layer_calendar, .calendar');
            if (cal) return cal;
            await sleep(200);
        }
        return null;
    };

    const calendar = await waitForCal();
    const prevBtn = topDoc.querySelector('.ui-datepicker-prev, .btn_prev');
    const nextBtn = topDoc.querySelector('.ui-datepicker-next, .btn_next');

    if (!calendar && !prevBtn && !nextBtn) {
        console.log("[date] calendar not found");
        return;
    }

    const today = new Date();
    const monthsDiff = (targetDate.getFullYear() - today.getFullYear()) * 12 + (targetDate.getMonth() - today.getMonth());
    if (monthsDiff !== 0) {
        const mover = monthsDiff > 0 ? nextBtn : prevBtn;
        const steps = Math.abs(monthsDiff);
        if (mover) {
            console.log("[date] move month " + (monthsDiff > 0 ? 'forward' : 'back') + " x" + steps);
            for (let i = 0; i < steps; i++) {
                mover.click();
                await sleep(250);
            }
            await sleep(300);
        }
    }

    const findDayButtons = () => {
        const roots = [calendar];
        const list = [];
        roots.forEach(root => {
            if (!root) return;
            list.push(...root.querySelectorAll('.ui-datepicker-calendar td button, .ui-datepicker-calendar td a'));
        });
        return list.filter(el => el.offsetParent !== null);
    };

    let dayButtons = findDayButtons();
    let targetDay = dayButtons.find(el => Number(el.innerText) === targetDate.getDate());

    for (let i = 0; i < 8 && !targetDay; i++) {
        await sleep(250);
        dayButtons = findDayButtons();
        targetDay = dayButtons.find(el => Number(el.innerText) === targetDate.getDate());
    }

    if (!targetDay && dayButtons.length > 0) {
        targetDay = dayButtons.find(el => el.className.includes('ui-state-active')) || dayButtons[0];
    }

    if (targetDay) {
        console.log("[date] select day " + targetDate.getDate());
        targetDay.scrollIntoView({ block: 'nearest' });
        targetDay.click();
    } else {
        console.log("[date] day element not found");
    }

    await sleep(400);
}
