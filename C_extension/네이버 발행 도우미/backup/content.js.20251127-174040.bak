// ----------------------------------------------------
// [0] ?좏떥由ы떚
// ----------------------------------------------------
const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

// ?띿뒪?몃줈 ?붿냼 李얘린 (Top Frame)
function findElementByText(text) {
    const doc = window.top.document; 
    const cleanTarget = text.replace(/\s/g, '');
    const all = doc.querySelectorAll('label, span, strong, b, div, p, h3, h4, li, a, button');
    
    for (let el of all) {
        if (el.innerText.replace(/\s/g, '').includes(cleanTarget) && el.offsetParent !== null) {
            if (el.childElementCount === 0) return el;
        }
    }
    return null;
}

// ??Tab) ?대룞: 湲곗? ?붿냼 諛붾줈 ?ㅼ쓬??'?낅젰 媛???붿냼' 諛섑솚
function getNextTabbable(anchor) {
    if (!anchor) return null;
    const doc = window.top.document;
    
    // ??媛?ν븳 紐⑤뱺 ?붿냼 (?붾㈃??蹂댁씠??寃껊쭔)
    const all = Array.from(doc.querySelectorAll('button, input, select, textarea, [tabindex]:not([tabindex="-1"])'))
        .filter(el => el.offsetWidth > 0 && el.offsetHeight > 0 && !el.disabled);

    for (let el of all) {
        if (anchor.compareDocumentPosition(el) & Node.DOCUMENT_POSITION_FOLLOWING) {
            return el;
        }
    }
    return null;
}

// ?ㅻ낫???꾨Ⅴ湲?function pressKey(element, key = 'Enter') {
    if (!element) return;
    element.focus();

    let code = 13;
    if (key === 'Space') code = 32;
    if (key === 'ArrowLeft') code = 37;
    if (key === 'ArrowRight') code = 39;

    const opts = { key: key, code: key, keyCode: code, which: code, bubbles: true, cancelable: true, view: window };
    
    element.dispatchEvent(new KeyboardEvent('keydown', opts));
    element.dispatchEvent(new KeyboardEvent('keypress', opts));
    element.dispatchEvent(new KeyboardEvent('keyup', opts));
    
    if(key === 'Enter' || key === 'Space') element.click();
}

function setNativeValue(element, value) {
  if (!element || !(element instanceof window.HTMLInputElement)) {
      console.error("???낅젰 媛?ν븳 ?붿냼媛 ?꾨떃?덈떎:", element);
      return;
  }
  
  const proto = window.HTMLInputElement.prototype;
  const setter = Object.getOwnPropertyDescriptor(proto, 'value').set;
  if (setter) setter.call(element, value);
  else element.value = value;
  element.dispatchEvent(new Event('input', { bubbles: true }));
}

function setFieldValue(element, value) {
  if (!element) return false;
  const strVal = String(value);

  if (element.tagName === 'SELECT') {
      const option = Array.from(element.options || []).find(opt => opt.value === strVal || opt.text.trim() === strVal);
      if (option) {
          element.value = option.value;
          element.dispatchEvent(new Event('input', { bubbles: true }));
          element.dispatchEvent(new Event('change', { bubbles: true }));
          return true;
      }
      return false;
  }

  if (element instanceof window.HTMLInputElement || element instanceof window.HTMLTextAreaElement) {
      setNativeValue(element, strVal);
      return true;
  }

  return false;
}

// ----------------------------------------------------
// [1] ?ㅽ뻾 由ъ뒪??// ----------------------------------------------------
document.addEventListener('keydown', (e) => {
  if (e.altKey && e.shiftKey && (e.key === 'p' || e.key === 'P')) {
    e.preventDefault();
    window.top.postMessage({ type: "REQ_PUBLISH_EXTENSION" }, "*");
  }
});

window.addEventListener("message", (event) => {
  if (event.data && event.data.type === "REQ_PUBLISH_EXTENSION" && window === window.top) {
      runSequence();
  }
});

chrome.runtime.onMessage.addListener((request) => {
  if (request.action === "TRIGGER_PUBLISH_BY_POPUP" && window === window.top) {
      runSequence();
  }
});

// ----------------------------------------------------
// [2] 硫붿씤 濡쒖쭅
// ----------------------------------------------------
async function runSequence() {
  const topDoc = window.top.document;

  // [1] 諛쒗뻾 踰꾪듉
  let publishBtn = topDoc.querySelector('.btn_publish');
  if (!publishBtn) {
      const allBtns = topDoc.querySelectorAll('button');
      for(let b of allBtns) {
          if(b.innerText.trim() === '諛쒗뻾' && b.offsetParent !== null) { publishBtn = b; break; }
      }
  }
  if (!publishBtn) return alert("??諛쒗뻾 踰꾪듉??紐?李얠븯?듬땲??");

  console.log("?⑨툘 [1] 諛쒗뻾 踰꾪듉 ?뷀꽣");
  pressKey(publishBtn, 'Enter');

  // ?ㅼ젙 濡쒕뱶
  const data = await chrome.storage.local.get(['settings', 'currentProfile']);
  const settings = (data.settings && data.settings[data.currentProfile || 'default']) || {};
  if (!settings.category) return alert("???ㅼ젙 ?놁쓬");

  // ?좎쭨 怨꾩궛
  const [sh, sm] = (settings.startTime || '09:00').split(':').map(Number);
  let targetDate = new Date();
  if(settings.lastScheduled) {
      const last = new Date(settings.lastScheduled);
      const interval = parseInt(settings.interval || 60);
      const variance = interval * 0.2; 
      const randomMin = (Math.random() * (variance * 2)) - variance;
      last.setMinutes(last.getMinutes() + interval + randomMin);
      targetDate = last;
  } else {
      targetDate.setHours(sh, sm);
      if(targetDate < new Date()) targetDate.setDate(targetDate.getDate() + 1);
  }
  
  // ???  const currentProfile = data.currentProfile || 'default';
  if(!data.settings[currentProfile]) data.settings[currentProfile] = {};
  data.settings[currentProfile].lastScheduled = targetDate.toISOString();
  await chrome.storage.local.set({ settings: data.settings });


  // [2] ?앹뾽 ?湲?  console.log("???앹뾽 ?湲?(2珥?...");
  await sleep(2000);

  // [3] 移댄뀒怨좊━ ?ㅼ젙
  const catLabel = findElementByText('移댄뀒怨좊━');
  if (catLabel) {
      const dropdown = getNextTabbable(catLabel); // Tab 1
      if (dropdown) {
          console.log("?⑨툘 [2] ?쒕∼?ㅼ슫 ?뷀꽣");
          pressKey(dropdown, 'Enter');
          await sleep(1000);
          
          const catItem = findElementByText(settings.category);
          if (catItem) {
              console.log(`?⑨툘 [3] ??ぉ ?좏깮: ${settings.category}`);
              pressKey(catItem, 'Enter');
              console.log("??由щ젋?붾쭅 ?湲?(2.5珥?...");
              await sleep(2500);
          }
      }
  }

  // [4] ?덉빟 ?ㅼ젙 (?? '?덉빟' ?쇰꺼?먯꽌 Tab 1??-> ?좎쭨 踰꾪듉)
  console.log("?뵇 '?덉빟' ?쇰꺼 寃??);
  let anchor = findElementByText('?덉빟') || findElementByText('?덉빟?쒓컙') || findElementByText('諛쒗뻾?쒓컙');

  if (anchor) {
      const dateBtn = getNextTabbable(anchor); // Tab 1

      if (dateBtn) {
          console.log("?⑨툘 [4] ?좎쭨 踰꾪듉 諛쒓껄 (?덉빟 ?쇰꺼 -> Tab 1?? -> ?ㅼ젙 ?쒖옉");
          
          // ?좎쭨 ?ㅼ젙 濡쒖쭅 ?ㅽ뻾
          await setDateManual(dateBtn, targetDate);
          
          // ?쒓컙/遺??낅젰 (?щ젰?먯꽌 鍮좎졇?섏삩 ?ъ빱??湲곗?)
          const hourInput = getNextTabbable(window.top.document.activeElement || dateBtn);
          const minInput = getNextTabbable(hourInput);

          if (hourInput && minInput) {
              const HH = targetDate.getHours();
              const mm = Math.round(targetDate.getMinutes() / 10) * 10;
              console.log(`?⑨툘 [5] ?쒓컙 ?낅젰: ${HH}:${mm}`);
              
              const okH = setFieldValue(hourInput, String(HH).padStart(2,'0'));
              const okM = setFieldValue(minInput, String(mm).padStart(2,'0'));
              if (!okH || !okM) console.log("?좑툘 ?쒓컙/遺??낅젰 ?ㅽ뙣 (?붿냼 ????뺤씤 ?꾩슂)");
          } else {
              console.log("?좑툘 ?쒓컙 ?낅젰移??먯깋 ?ㅽ뙣");
          }
      } else {
          console.log("?좑툘 ?덉빟 ?쇰꺼 ?ㅼ쓬 ?ъ빱?ㅺ? ?좎쭨 踰꾪듉???꾨떃?덈떎.");
      }
  } else {
      console.log("?좑툘 '?덉빟/諛쒗뻾 ?쒓컙' ?쇰꺼??李얠? 紐삵뻽?듬땲??");
  }

  // [5] 理쒖쥌 ?뺤씤
  await sleep(1000);
  const confirmMsg = `
  [?ㅼ젙 ?뺤씤]
  移댄뀒怨좊━: ${settings.category}
  ?덉빟?쒓컙: ${targetDate.getMonth()+1}/${targetDate.getDate()} ${targetDate.getHours()}:${Math.round(targetDate.getMinutes()/10)*10}
  
  諛쒗뻾?좉퉴??`;

  if(confirm(confirmMsg)) {
      const allBtns = topDoc.querySelectorAll('button');
      let finalBtn = null;
      let maxTop = 0;
      for(let b of allBtns) {
          if(b.innerText.trim() === '諛쒗뻾' && !b.className.includes('btn_publish') && b.offsetParent !== null) {
              const rect = b.getBoundingClientRect();
              if(rect.top > maxTop) { maxTop = rect.top; finalBtn = b; }
          }
      }
      if(finalBtn) {
          console.log("?? 理쒖쥌 諛쒗뻾 ?뷀꽣!");
          pressKey(finalBtn, 'Enter');
      }
  }
}

// ?좎쭨 ?ㅼ젙 (?ъ슜??留ㅻ돱??
// 날짜 설정 (keyboard flow)
async function setDateManual(dateBtn, targetDate) {
    console.log('⌨️ 날짜 버튼 엔터 (달력 열기)');
    pressKey(dateBtn, 'Enter');
    await sleep(500);

    const topDoc = window.top.document;

    // 1) 날짜 초기화: ArrowLeft + Space x4 (오늘이 포함된 달로 이동)
    const resetTarget = topDoc.querySelector('.layer_calendar .btn_prev, .calendar .btn_prev') || topDoc.activeElement;
    if (resetTarget) {
        console.log('⌨️ 초기화: [ArrowLeft] + [Space] x4');
        resetTarget.focus();
        for (let i = 0; i < 4; i++) {
            pressKey(resetTarget, 'ArrowLeft');
            await sleep(80);
            pressKey(resetTarget, 'Space');
            await sleep(120);
        }
    }

    // 2) 초기화 직후 Enter로 포커스 확정
    console.log('⌨️ 초기화 후 엔터');
    if (topDoc.activeElement) pressKey(topDoc.activeElement, 'Enter');
    await sleep(150);

    // 3) 목표 달로 이동 (미래 달: Tab -> Space로 월 +1)
    const today = new Date();
    const monthDiff = (targetDate.getFullYear() - today.getFullYear()) * 12 + (targetDate.getMonth() - today.getMonth());
    if (monthDiff > 0) {
        console.log(`⌨️ 월 앞으로 이동 x ${monthDiff}`);
        let focusEl = topDoc.activeElement;
        for (let m = 0; m < monthDiff; m++) {
            focusEl = getNextTabbable(focusEl);
            if (focusEl) {
                focusEl.focus();
                pressKey(focusEl, 'Space');
                await sleep(200);
            }
        }
    }

    // 4) 날짜 선택 (탭 이동 후 Space)
    const todayDay = today.getDate();
    const targetDay = targetDate.getDate();
    let tabCount;
    if (monthDiff === 0) {
        tabCount = (targetDay - todayDay) + 2; // 같은 달: 오늘=2, 내일=3 ...
    } else {
        tabCount = targetDay + 1; // 다른 달: 원하는 날짜+1
    }
    tabCount = Math.max(1, tabCount);

    console.log(`⌨️ 날짜 탭 이동 x ${tabCount}`);

    let currentEl = topDoc.activeElement;
    for (let i = 0; i < tabCount; i++) {
        currentEl = getNextTabbable(currentEl);
        if (currentEl) currentEl.focus();
    }

    if (topDoc.activeElement) {
        pressKey(topDoc.activeElement, 'Space');
    }

    await sleep(300);
}

