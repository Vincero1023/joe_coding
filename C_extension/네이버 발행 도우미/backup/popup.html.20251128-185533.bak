<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body { width: 360px; padding: 14px; margin: 0; font-family: '"'"'Malgun Gothic'"'"', sans-serif; font-size: 13px; color: #1b1b1b; background: linear-gradient(135deg, #f5fff7, #f0f7ff); }
    .panel { background: #fff; border-radius: 12px; box-shadow: 0 6px 20px rgba(0,0,0,0.08); padding: 12px; }
    h3 { margin-top: 0; color: #03C75A; border-bottom: 2px solid #03C75A; padding-bottom: 8px; }
    .group { margin-bottom: 15px; border: 1px solid #e6e6e6; padding: 12px; border-radius: 8px; background: #fafafa; }
    label { display: block; margin-bottom: 6px; font-weight: bold; color: #444; }
    input[type="text"], select { width: 100%; padding: 8px; margin-bottom: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; background: #fff; }
    .time-wrapper { display: flex; align-items: center; gap: 5px; margin-bottom: 8px; flex-wrap: wrap; }
    .time-input { width: 52px !important; text-align: center; font-size: 14px; font-weight: bold; padding: 5px !important; }
    .colon { font-weight: bold; color: #777; }
    .row { display: flex; gap: 5px; margin-bottom: 5px; }
    button { width: 100%; padding: 12px; border: none; cursor: pointer; font-weight: bold; color: white; border-radius: 5px; margin-top: 5px; transition: 0.2s; }
    #saveBtn { background: #555; }
    #saveBtn.saved { background: #2196F3; }
    #runBtn { background: #03C75A; font-size: 1.05em; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
    #runBtn:hover { background: #029f48; }
    .date-btn-group { display: flex; gap: 5px; margin-bottom: 10px; }
    .date-btn { flex: 1; padding: 8px; font-size: 12px; background: #fff; color: #333; border: 1px solid #ccc; border-radius: 4px; margin-top: 0; cursor: pointer; }
    .date-btn:hover { background: #eee; }
    .info { font-size: 11px; color: #888; margin-top: 3px; }
    .btn-mini { width: 40px; background: #ddd; color: #333; padding: 8px; margin-top: 0; }
    .toggle-row { display: flex; align-items: center; gap: 8px; margin: 4px 0; flex-wrap: wrap; }
    .toggle-row input { width: auto; }
  </style>
</head>
<body>
  <div class="panel">
    <h3>네이버 블로그 발행 비서</h3>

    <div class="group">
      <label>설정 프로필</label>
      <div class="row">
        <select id="profileSelect" style="margin-bottom:0;"><option value="default">default</option></select>
        <button id="addProfileBtn" class="btn-mini">+</button>
        <button id="delProfileBtn" class="btn-mini">-</button>
      </div>
    </div>

    <div class="group">
      <label>카테고리 (정확한 이름)</label>
      <input type="text" id="categoryName" placeholder="예: 잡화">

      <label>예약 기준일 설정</label>
      <div class="date-btn-group">
        <button id="setTodayBtn" class="date-btn">오늘</button>
        <button id="setTomorrowBtn" class="date-btn">내일</button>
      </div>

      <label>시작 시간</label>
      <div class="time-wrapper">
        <input type="number" id="startHour" class="time-input" min="0" max="23" placeholder="09">
        <span class="colon">:</span>
        <input type="number" id="startMin" class="time-input" min="0" max="59" placeholder="00">
        <span class="info" style="margin-left:5px;">(첫 발행)</span>
      </div>

      <label>발행 간격 (분)</label>
      <input type="number" id="intervalMin" value="60" style="width:100%">

      <hr style="border:0; border-top:1px dashed #ccc; margin:10px 0;">

      <label>발행 금지 시간 (시:분)</label>
      <div class="toggle-row">
        <input type="checkbox" id="blockEnabled">
        <span style="font-weight:bold;">금지시간 사용</span>
        <span class="info">(체크 시 해당 시간대 자동 발행 안 함)</span>
      </div>
      <div class="time-wrapper">
        <input type="number" id="blockStartH" class="time-input" placeholder="23">
        <span class="colon">:</span>
        <input type="number" id="blockStartM" class="time-input" placeholder="00">
        <span class="colon">~</span>
        <input type="number" id="blockEndH" class="time-input" placeholder="07">
        <span class="colon">:</span>
        <input type="number" id="blockEndM" class="time-input" placeholder="00">
      </div>
    </div>

    <div class="group">
      <label>마지막 예약 이력</label>
      <input type="text" id="lastScheduledInfo" disabled style="background:#eee; color:#666;">
      <button id="resetTimeBtn" style="background: #ff9800; padding: 6px; font-size:12px;">기록 초기화</button>
    </div>

    <div class="row">
      <button id="saveBtn">설정 저장</button>
      <button id="runBtn">자동 발행 실행</button>
    </div>
  </div>

  <script src="popup.js"></script>
</body>
</html>
