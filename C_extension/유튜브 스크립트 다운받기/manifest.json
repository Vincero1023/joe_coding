{
  "manifest_version": 3,
  "name": "\uC720\uD29C\uBE0C \uC790\uB9C9 \uCC98\uB9AC&\uC694\uC57D",
  "description": "View and download YouTube transcripts, then prepare AI summary and manual prompts.",
  "version": "1.5.4",
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "scripting",
    "sidePanel",
    "notifications",
    "offscreen",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.youtube-nocookie.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://grok.com/*",
    "https://chat.mistral.ai/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "offscreen.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "\uC720\uD29C\uBE0C \uC790\uB9C9 \uCC98\uB9AC&\uC694\uC57D",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "transcript.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content_shortcuts.js"
      ],
      "run_at": "document_start"
    }
  ],
  "commands": {
    "open_transcript_1": {
      "description": "Open transcript text for current YouTube video",
      "suggested_key": {
        "default": "Ctrl+Shift+1"
      }
    },
    "copy_transcript_2": {
      "description": "Copy transcript text for current YouTube video",
      "suggested_key": {
        "default": "Ctrl+Shift+2"
      }
    },
    "download_transcript_3": {
      "description": "Download transcript for current YouTube video",
      "suggested_key": {
        "default": "Ctrl+Shift+3"
      }
    },
    "summarize_transcript_4": {
      "description": "Prepare GPT summary prompt for current YouTube video",
      "suggested_key": {
        "default": "Ctrl+Shift+4"
      }
    }
  }
}
